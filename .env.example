# ============================
# DevPilot AI — Environment Variables
# ============================
# Copy this file to .env and fill in your values
# NOTE: Place frontend variables in frontend/.env.local
# NOTE: Place backend variables in backend/.env

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
# Replace with your MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/devpilot

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── Groq AI ───────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── GitHub OAuth (optional — only needed for GitHub login) ─
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# ── Frontend URL ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Frontend Specific (.env.local in frontend folder) ─────
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
