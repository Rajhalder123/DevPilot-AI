# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/devpilot?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# ── Groq AI ───────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key

# ── GitHub OAuth ──────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://YOUR_BACKEND_URL/api/auth/github/callback

# ── Frontend URL (CORS + redirects) ──────────────────────
FRONTEND_URL=https://your-frontend.vercel.app,https://your-admin.vercel.app

# ── Cloudflare Turnstile ─────────────────────────────────
CLOUDFLARE_TURNSTILE_SECRET=your_turnstile_secret
